# Python
__pycache__/
*.py[cod]
*.pyd
.pytest_cache/
.mypy_cache/

# Virtual env
.venv/
venv/
.env/

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Test artifacts
.coverage
htmlcov/

# IDE
.vscode/
.idea/

# Runtime data (audit logs contain subject tokens)
data/audit/
data/cache/
data/evidence/
data/registry/

# Off-chain LLM research notes — non-evidentiary, non-replayable,
# operator-only research output from backend.research_artifacts.llm_assist.
# Per the 2026-05-27 standing-instruction override governance event, these
# artifacts deliberately do NOT participate in the audit chain or evidence
# replay; they are local-only commentary the operator reads and acts on.
data/llm_notes/

# Watchlist snapshots — regenerated daily by backend.jobs.watchlist
data/snapshots/

# Diagnostic dumps
data/sample_realistic_response.json

# Local backup bundles — git bundle archives kept locally as snapshots,
# not version-controlled (would duplicate repo state inside the repo)
*.bundle

# Rendered scheduler artifacts. Templates under scripts/ are tracked;
# the substituted output is per-machine (contains absolute install
# paths, venv python paths, etc.) and must never round-trip back into
# git. Today install_scheduler.py emits scripts/scheduler-task.rendered.xml
# on Windows; Phase C will add the same rendered/template split on macOS.
# Defensive entry added now to protect the repo boundary in advance.
scripts/*.rendered.*
