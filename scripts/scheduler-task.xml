<?xml version="1.0" encoding="UTF-16"?>
<!--
  Windows Task Scheduler equivalent of the macOS launchd plist
  (com.investment-analytics.scheduler.plist) and the POSIX cron line
  (cron-line.txt). Runs the daily evidence cadence every weekday at
  21:30 local time — the same cadence the macOS and Linux artifacts
  produce, with the same scheduler runner and the same DAG.

  Placeholders to substitute at install time (do NOT hand-edit
  unless you know the paths):
    {{INSTALL_ROOT}}      → absolute path to the repo (no trailing slash)
    {{PYTHON_EXE}}        → absolute path to venv\Scripts\python.exe
    {{START_BOUNDARY}}    → any future timestamp (Task Scheduler
                            requires a start boundary; the calendar
                            trigger fires regardless on weekday
                            schedule). ISO 8601 form, no zone.

  Install:
    schtasks /Create /TN "InvestmentAnalyticsScheduler" /XML scripts\scheduler-task.xml

  Uninstall:
    schtasks /Delete /TN "InvestmentAnalyticsScheduler" /F

  The Python scheduler ITSELF runs unchanged — same cadence DAG,
  same lock discipline (now via the cross-platform _locking
  adapter), same pre-flight chain verification, same audit
  emission, same refusal semantics. Only the OS-level cadence
  trigger differs from launchd/cron; everything below the trigger
  is identical.
-->
<Task version="1.4" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">
  <RegistrationInfo>
    <Description>Investment Analytics evidence cadence (daily weekday evening).</Description>
    <URI>\InvestmentAnalyticsScheduler</URI>
  </RegistrationInfo>
  <Triggers>
    <CalendarTrigger>
      <StartBoundary>{{START_BOUNDARY}}</StartBoundary>
      <Enabled>true</Enabled>
      <ScheduleByWeek>
        <DaysOfWeek>
          <Monday/>
          <Tuesday/>
          <Wednesday/>
          <Thursday/>
          <Friday/>
        </DaysOfWeek>
        <WeeksInterval>1</WeeksInterval>
      </ScheduleByWeek>
    </CalendarTrigger>
  </Triggers>
  <Principals>
    <Principal id="Author">
      <LogonType>InteractiveToken</LogonType>
      <RunLevel>LeastPrivilege</RunLevel>
    </Principal>
  </Principals>
  <Settings>
    <MultipleInstancesPolicy>IgnoreNew</MultipleInstancesPolicy>
    <DisallowStartIfOnBatteries>false</DisallowStartIfOnBatteries>
    <StopIfGoingOnBatteries>false</StopIfGoingOnBatteries>
    <AllowHardTerminate>true</AllowHardTerminate>
    <StartWhenAvailable>true</StartWhenAvailable>
    <RunOnlyIfNetworkAvailable>false</RunOnlyIfNetworkAvailable>
    <IdleSettings>
      <StopOnIdleEnd>false</StopOnIdleEnd>
      <RestartOnIdle>false</RestartOnIdle>
    </IdleSettings>
    <AllowStartOnDemand>true</AllowStartOnDemand>
    <Enabled>true</Enabled>
    <Hidden>false</Hidden>
    <RunOnlyIfIdle>false</RunOnlyIfIdle>
    <WakeToRun>false</WakeToRun>
    <ExecutionTimeLimit>PT2H</ExecutionTimeLimit>
    <Priority>7</Priority>
  </Settings>
  <Actions Context="Author">
    <Exec>
      <Command>{{PYTHON_EXE}}</Command>
      <Arguments>-m backend.scheduler run-cadence daily_weekday_evening</Arguments>
      <WorkingDirectory>{{INSTALL_ROOT}}</WorkingDirectory>
    </Exec>
  </Actions>
</Task>
